{
  "name": "resilienz-ai-diagrams",
  "version": "1.0.0",
  "description": "Mermaid diagram definitions for Resilienz.AI",
  "scripts": {
    "generate": "npm run generate:architecture && npm run generate:agent-flow && npm run generate:simulation",
    "generate:architecture": "npx mmdc -i mermaid/architecture.mmd -o images/architecture.png -b transparent -w 2400 -H 1600 -s 2",
    "generate:agent-flow": "npx mmdc -i mermaid/agent-flow.mmd -o images/agent-flow.png -b transparent -w 2000 -H 1800 -s 2",
    "generate:simulation": "npx mmdc -i mermaid/simulation.mmd -o images/simulation.png -b transparent -w 1600 -H 1200 -s 2",
    "watch": "onchange 'mermaid/*.mmd' -- npm run generate"
  },
  "devDependencies": {
    "@mermaid-js/mermaid-cli": "^11.4.2",
    "onchange": "^7.1.0"
  }
}
