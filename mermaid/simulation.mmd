%%{init: {
  'theme': 'dark',
  'themeVariables': {
    'primaryColor': '#4f46e5',
    'primaryTextColor': '#fff',
    'primaryBorderColor': '#818cf8',
    'lineColor': '#94a3b8',
    'secondaryColor': '#1e293b',
    'tertiaryColor': '#0f172a',
    'background': '#0f172a',
    'mainBkg': '#1e293b',
    'nodeBorder': '#818cf8',
    'titleColor': '#f1f5f9',
    'edgeLabelBackground': '#1e293b'
  },
  'flowchart': {
    'htmlLabels': true,
    'curve': 'basis',
    'nodeSpacing': 50,
    'rankSpacing': 80
  }
}}%%

flowchart LR
    subgraph Trigger["👤 User Triggers Scenario"]
        Select["📋 Select from Dropdown"]
        Click["▶️ Click 'Trigger'"]
    end
    
    subgraph Apply["💾 In-Memory Application"]
        DB[(🗄️ SQLite)]
        VDB[(🔎 ChromaDB)]
        
        Select -->|"scenario_id"| API
        API -->|"delay_modifier"| ApplyDB["➕ Apply Delay Overrides"]
        API -->|"inject_event"| ApplyVDB["📝 Add Scenario Event"]
        
        ApplyDB -.-> DB
        ApplyVDB -.-> VDB
    end
    
    subgraph Observe["📊 Dashboard Updates"]
        Map["🗺️ Risk Map Updates"]
        Stats["📈 Metrics Recalculate"]
        Alert["🚨 Scenario Badge Active"]
    end
    
    DB -.-> Map
    VDB -.-> Map
    DB -.-> Stats
    DB -.-> Alert

    style Trigger fill:#312e81,stroke:#818cf8,stroke-width:2px
    style Apply fill:#1e3a5f,stroke:#38bdf8,stroke-width:2px
    style Observe fill:#1e3a3f,stroke:#2dd4bf,stroke-width:2px
    
    Select -->|"1. User Select"| Click
    Click -->|"2. Trigger"| Apply
    
    Map -->|"3a. Visual"| Observe
    Stats -->|"3b. Data"| Observe
    Alert -->|"3c. Status"| Observe

    classDef db fill:#1f2937,stroke:#9ca3af,stroke-width:2px
    class DB,VDB db
